# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub ─────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...              # Fine-grained PAT: repo:read, deployments:read
GITHUB_REPO=your-org/your-repo   # e.g. acme/api-service

# ── Datadog ────────────────────────────────────────────────────────────────
DD_API_KEY=...
DD_APP_KEY=...

# ── Jira ───────────────────────────────────────────────────────────────────
JIRA_SERVER=https://your-org.atlassian.net
JIRA_EMAIL=you@your-org.com
JIRA_API_TOKEN=...               # From id.atlassian.com/manage-profile/security/api-tokens

# ── Confluence ─────────────────────────────────────────────────────────────
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_EMAIL=you@your-org.com
CONFLUENCE_API_TOKEN=...         # Same token as Jira works for Atlassian Cloud

# ── Slack ──────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...         # Bot token with chat:write scope
SLACK_SIGNING_SECRET=...         # For the Slack bot webhook (interfaces/slack_bot)

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_PATH=/tmp/opsiq.db      # SQLite (dev). Set DATABASE_URL for Postgres (cloud).

# ── API ────────────────────────────────────────────────────────────────────
OPSIQ_API_URL=http://localhost:8000
